[
  {
    "match": "**/*",
  },
  {
    "match": ".well-known",
    "ignore": false
  },
  {
    "match": ".well-known/**/*",
    "ignore": false,
    "headers": {
      "Content-Type": "text/plain; charset=utf-8",
      "Cache-Control": "public, max-age=0"
    }
  },
  {
    "match": ".well-known/ii-alternative-origins",
    "ignore": false,
    "headers": {
      "Access-Control-Allow-Origin": "*",
      "Content-Type": "application/json",
      "Cache-Control": "public, max-age=0"
    }
  }
]
